  "searchKey": "",
  "tableData": "{{ Object.entries(appsmith.store.build?.parts || {}).map(([type, part]) => {\n  const s = part?.specs || {};\n  const prettyType = String(type).toUpperCase();\n\n  // Pick ONE key spec per part type (simple + readable)\n  let keySpec = \"\";\n  if (type === \"cpu\") keySpec = `${s.cores ?? \"?\"}C / ${s.threads ?? \"?\"}T`;\n  else if (type === \"gpu\") keySpec = `${s.vramGB ?? \"?\"}GB VRAM`;\n  else if (type === \"ram\") keySpec = `${s.sizeGB ?? \"?\"}GB ${s.type ?? \"\"}`.trim();\n  else if (type === \"storage\") keySpec = `${Math.round((s.sizeGB ?? 0) / 1000)}TB ${s.type ?? \"\"}`.trim();\n  else if (type === \"motherboard\") keySpec = `${s.socket ?? \"\"} ${s.formFactor ?? \"\"}`.trim();\n  else if (type === \"psu\") keySpec = `${s.wattage ?? \"?\"}W`;\n  else if (type === \"case\") keySpec = `${s.formFactor ?? \"\"}`.trim();\n\n  return {\n    Part: prettyType,\n    Name: part?.name ?? \"\",\n    Price: part?.price ?? null,\n    \"Key Spec\": keySpec\n  };\n}) }}",
